GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_here
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BOOKMAKER=your_api_football_bookmaker_here
# Danh sách league id, phân tách bằng dấu phẩy. Mặc định: 1=World Cup, 39=Premier League, 2=Champions League.
API_FOOTBALL_LEAGUE=1,39,2
# RLS đã enable trên các bảng, không có policy cho anon — phải dùng service_role key
# (Settings → API trong dashboard Supabase), không dùng anon/publishable key. Secret, chỉ
# dùng server-side, không bao giờ nhúng vào client/web app.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here
GITHUB_OWNER=your_github_owner_here
GITHUB_REPO=your_github_repo_here
GITHUB_PAT=your_github_fine_grained_pat_here
GITHUB_REF=main
