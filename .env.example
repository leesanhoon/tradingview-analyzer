# AI cho luồng chart
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Ngưỡng confidence tối thiểu để giữ setup chart
CHART_SIGNAL_CONFIDENCE_THRESHOLD=70
# Model chính để phân tích chart
CHART_VERIFY_MODEL_PRIMARY=gemini-2.5-pro
# Model chính để phân tích toàn bộ bộ ảnh chart
CHART_ANALYSIS_MODEL=gemini-3.5-flash
# Claude fallback cho bước verify chart
CHART_VERIFY_MODEL_CLAUDE=claude-sonnet-4-6
# Model dùng cho bước verify vị thế đang mở
POSITION_VERIFY_MODEL_GEMINI=gemini-2.5-pro
# Claude fallback cho bước verify vị thế đang mở
POSITION_VERIFY_MODEL_CLAUDE=claude-sonnet-4-6
# Model chính / dự phòng cho betting odds
BETTING_VERIFY_MODEL_PRIMARY=gemini-2.5-pro
BETTING_VERIFY_MODEL_FALLBACK=gemini-3.5-flash
VERIFY_PROVIDER=gemini
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram bot và webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_here

# Betting / football odds
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BOOKMAKER=your_api_football_bookmaker_here
# Danh sách league id, phân tách bằng dấu phẩy. Mặc định: 1=World Cup, 39=Premier League, 2=Champions League.
API_FOOTBALL_LEAGUE=1,39,2

# RLS đã enable trên các bảng, không có policy cho anon — phải dùng service_role key
# (Settings → API trong dashboard Supabase), không dùng anon/publishable key. Secret, chỉ
# dùng server-side, không bao giờ nhúng vào client/web app.
# Supabase cho webhook, logs, metrics và AI usage
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here
# GitHub Actions dispatch qua Telegram webhook
GITHUB_OWNER=your_github_owner_here
GITHUB_REPO=your_github_repo_here
GITHUB_PAT=your_github_fine_grained_pat_here
GITHUB_REF=main
